{
    "name": "gainbridge-mobile-qa",
    "version": "1.0.0",
    "description": "Mobile Automation Framework for DemoShop",
    "type": "module",
    "scripts": {
        "test:smoke": "npx wdio run wdio.conf.ts --suite all --mochaOpts.grep @smoke",
        "test:regression": "npx wdio run wdio.conf.ts --suite all --mochaOpts.grep @regression",
        "test:e2e": "npx wdio run wdio.conf.ts --suite e2e",
        "test:actions": "npx wdio run wdio.conf.ts --suite actions",
        "test:all": "npx wdio run wdio.conf.ts",
        "lint": "eslint src/**/*.ts",
        "format": "prettier --write \"src/**/*.ts\"",
        "report:generate": "allure generate allure-results --clean",
        "report:open": "allure open",
        "report": "npm run report:generate && npm run report:open"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "@wdio/allure-reporter": "^9.0.0",
        "@wdio/appium-service": "^9.0.0",
        "@wdio/cli": "^9.0.0",
        "@wdio/globals": "^9.0.0",
        "@wdio/local-runner": "^9.0.0",
        "@wdio/mocha-framework": "^9.0.0",
        "@wdio/spec-reporter": "^9.0.0",
        "allure-commandline": "^2.30.0",
        "appium": "^2.11.0",
        "appium-uiautomator2-driver": "^3.7.0",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-wdio": "^8.0.0",
        "expect-webdriverio": "^5.0.0",
        "prettier": "^3.3.0",
        "ts-node": "^10.9.0",
        "typescript": "^5.5.0"
    },
    "dependencies": {
        "dotenv": "^16.4.0"
    }
}
